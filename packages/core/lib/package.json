{
  "name": "@workspace/lib",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "exports": {
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf dist node_modules .turbo"
  },
  "devDependencies": {
    "@workspace/eslint-config": "*",
    "@workspace/typescript-config": "*",
    "@types/node": "^22.15.3",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "eslint": "^10.0.2",
    "typescript": "5.9.2"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "dotenv-expand": "^12.0.3",
    "tailwind-merge": "^3.4.1",
    "zod": "^4.3.6"
  }
}